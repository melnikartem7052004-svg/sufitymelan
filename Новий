<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sufity Melan</title>

<style>

body{
margin:0;
font-family:Arial,sans-serif;
background:#fff;
}

.hero{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.55)),
url('hero.jpg');
background-size:cover;
background-position:center;
color:white;
position:relative;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
}

.logo{
height:70px;
}

.menu{
font-size:40px;
color:white;
}

.content{
padding:40px 25px;
margin-top:80px;
}

h1{
font-size:58px;
line-height:1.1;
margin-bottom:20px;
}

.gold{
color:#d9b36a;
}

.desc{
font-size:24px;
line-height:1.5;
max-width:600px;
}

.buttons{
display:flex;
gap:15px;
margin-top:35px;
flex-wrap:wrap;
}

.btn{
padding:18px 28px;
border-radius:12px;
text-decoration:none;
font-weight:bold;
}

.call{
background:#d9b36a;
color:black;
}

.quote{
background:black;
color:white;
border:1px solid #d9b36a;
}

.features{
background:#080808;
color:white;
display:grid;
grid-template-columns:repeat(4,1fr);
text-align:center;
padding:35px 15px;
}

.feature{
padding:10px;
}

.gallery{
padding:70px 20px;
text-align:center;
}

.gallery-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:15px;
}

.gallery-grid img{
width:100%;
border-radius:15px;
}

.calc{
background:#111;
color:white;
padding:50px 25px;
}

.calc-box{
max-width:700px;
margin:auto;
}

select,input{
width:100%;
padding:18px;
margin-top:15px;
margin-bottom:15px;
border-radius:10px;
border:none;
background:#222;
color:white;
}

.result{
font-size:32px;
font-weight:bold;
text-align:center;
margin-top:20px;
color:#d9b36a;
}

</style>
</head>

<body>

<section class="hero">

<div class="topbar">
<img src="logo.png" class="logo">
<div class="menu">☰</div>
</div>

<div class="content">

<h1>
Nowoczesne<br>
Sufity Napinane<br>
<span class="gold">Premium</span>
</h1>

<p class="desc">
Profesjonalny montaż sufitów napinanych,
linii LED i sufitów premium.
Darmowa wycena w 24h.
</p>

<div class="buttons">

<a href="tel:+48734625102" class="btn call">
📞 Zadzwoń teraz
</a>

<a href="#form" class="btn quote">
📋 Otrzymaj bezpłatną wycenę
</a>

</div>

</div>

</section>
